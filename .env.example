# Claude (Anthropic) API key — get one at https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-...

# Mantle RPC URL override (optional — public endpoints used if not set)
# Testnet: https://rpc.sepolia.mantle.xyz
# Mainnet: https://rpc.mantle.xyz
MANTLE_RPC_URL=

# Target network: "testnet" or "mainnet" (default: testnet)
NEXT_PUBLIC_CHAIN=testnet

# AbyssAttest contract address — set after deploying (see scripts/deploy.ts)
NEXT_PUBLIC_ATTEST_CONTRACT=

# Private key for contract deployment — never commit, never share
DEPLOY_PRIVATE_KEY=
